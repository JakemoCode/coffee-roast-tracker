{
  "name": "client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.build.json && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:schema": "npx tsx scripts/extract-schema.ts && npx gql-tada generate-output && npx gql-tada turbo --output ./src/graphql/graphql-cache.d.ts",
    "validate:schema": "npx tsx scripts/validate-operations.ts"
  },
  "dependencies": {
    "@apollo/client": "^4.1.0",
    "@clerk/clerk-react": "^5.20.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "gql.tada": "^1.9.1",
    "graphql": "^16.10.0",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.4.0"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
    "@graphql-tools/mock": "^9.1.5",
    "@graphql-tools/schema": "^10.0.31",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.1"
  }
}
