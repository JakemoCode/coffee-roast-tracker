DATABASE_URL="postgresql://user:password@localhost:5432/coffee_roast_tracker"
# Direct (unpooled) URL for migrations. On Neon this is the non-pooled
# host; locally it's the same as DATABASE_URL. Optional — falls back to
# DATABASE_URL if unset.
# DIRECT_URL="postgresql://user:password@localhost:5432/coffee_roast_tracker"
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="coffee-roast-files"
R2_PUBLIC_URL=""
PORT=4000

# Test database (create manually: createdb coffee_roast_tracker_test)
# Copy to .env.test with real credentials for test suite
# TEST_DATABASE_URL="postgresql://user:password@localhost:5432/coffee_roast_tracker_test"
