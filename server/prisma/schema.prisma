generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  clerkId          String   @unique
  tempUnit         TempUnit @default(CELSIUS)
  theme            String   @default("LATTE")
  privateByDefault Boolean  @default(false)

  userBeans UserBean[]
  roasts    Roast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bean {
  id       String  @id @default(cuid())
  name     String
  // Lowercased, whitespace-collapsed name for case/whitespace-insensitive dedup.
  // Nullable for back-compat with rows created before this column existed; new
  // rows always populate it via the createBean resolver.
  normalizedName String? @unique
  origin   String?
  process  String?
  cropYear  Int?
  sourceUrl String?
  elevation String?
  variety   String?  // Varietal/cultivar (e.g. Bourbon, Caturra, SL28)
  bagNotes  String?
  supplier  String?  // Bean supplier/vendor (e.g. "Sweet Maria's")
  score     Float?   // SCA/cupping score (typically 0-100)
  suggestedFlavors String[] // Flavor names from supplier/scraper, editable by user

  userBeans UserBean[]
  roasts    Roast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBean {
  id        String  @id @default(cuid())
  notes     String?
  shortName String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  beanId String
  bean   Bean   @relation(fields: [beanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, beanId])
  @@index([userId, shortName])
}

enum TempUnit {
  CELSIUS
  FAHRENHEIT
}

enum FileType {
  KLOG
  CSV
}

enum ProfileType {
  KAFFELOGIC
}

enum FlavorCategory {
  FRUITY
  SOUR_FERMENTED
  GREEN_VEGETATIVE
  OTHER
  ROASTED
  SPICES
  NUTTY_COCOA
  SWEET
  FLORAL
  OFF_FLAVOR
}

model Roast {
  id String @id @default(cuid())

  // Header metadata from .klog
  ambientTemp        Float?  // °C, from ambient_temperature header
  roastingLevel      Float?  // KL roasting level e.g. 4.3
  tastingNotes       String? // from tasting_notes header; distinct from user notes

  // Event marker timestamps (from !-prefixed rows in time-series)
  colourChangeTime   Float?  // seconds, from !colour_change
  firstCrackTime     Float?  // seconds
  roastEndTime       Float?  // seconds, from !roast_end

  // Temperatures at event markers
  colourChangeTemp   Float?  // °C at !colour_change timestamp
  firstCrackTemp     Float?  // °C (always stored in Celsius)
  roastEndTemp       Float?  // °C (always stored in Celsius)

  // Phase data
  developmentTime    Float?  // seconds
  developmentPercent Float?  // from !development_percent e.g. 13.7606 (DTR%)
  totalDuration      Float?  // seconds
  roastDate          DateTime?

  // Time-series and curve data for chart rendering (all temps in °C)
  timeSeriesData     Json?   // [{time, spotTemp, temp, meanTemp, profileTemp, profileROR, actualROR, desiredROR, powerKW, actualFanRPM}]
  roastProfileCurve  Json?   // decoded roast_profile header: [{time, temp}]
  fanProfileCurve    Json?   // decoded fan_profile header: [{time, rpm}]

  notes  String?
  rating Float?    // 1.0–5.0 in 0.5 increments

  // Visibility
  isPublic Boolean @default(true)

  // SHA-256 of the source .klog file contents. Used to dedup re-uploads of the
  // same file under a different name. Nullable for back-compat with roasts
  // created before this column existed.
  contentHash String?

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  beanId String
  bean   Bean   @relation(fields: [beanId], references: [id], onDelete: Cascade)

  roastFiles   RoastFile[]
  roastProfile RoastProfile?
  espressoShot EspressoShot?
  roastFlavors RoastFlavor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contentHash])
  @@index([userId, createdAt(sort: Desc)])
  @@index([beanId, userId, roastDate(sort: Desc)])
}

model RoastFile {
  id       String   @id @default(cuid())
  fileKey  String // R2 object key
  fileName String // original filename
  fileType FileType

  roastId String
  roast   Roast  @relation(fields: [roastId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([roastId])
}

model RoastProfile {
  id          String      @id @default(cuid())
  fileKey     String // R2 object key
  fileName    String // original filename, preserved for download
  profileType ProfileType @default(KAFFELOGIC)

  profileShortName String? // from profile_short_name header e.g. "EGB"
  profileDesigner  String? // from profile_designer header e.g. "jakemo"

  roastId String @unique
  roast   Roast  @relation(fields: [roastId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([roastId])
}

// Stretch goal — model scaffolded, no resolvers in v1
model EspressoShot {
  id    String @id @default(cuid())
  dose  Float? // grams
  yield Float? // grams
  time  Float? // seconds
  tds   Float? // total dissolved solids %
  notes String?

  roastId String @unique
  roast   Roast  @relation(fields: [roastId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([roastId])
}

model FlavorDescriptor {
  id          String         @id @default(cuid())
  name        String         @unique
  category    FlavorCategory
  isOffFlavor Boolean        @default(false)
  isParent    Boolean        @default(false)
  isQuality   Boolean        @default(false)
  isCustom    Boolean        @default(false)
  color       String         // Hex color inherited from category
  roasts      RoastFlavor[]
  createdAt   DateTime       @default(now())
}

model RoastFlavor {
  roast        Roast            @relation(fields: [roastId], references: [id], onDelete: Cascade)
  roastId      String
  descriptor   FlavorDescriptor @relation(fields: [descriptorId], references: [id])
  descriptorId String
  createdAt    DateTime         @default(now())

  @@id([roastId, descriptorId])
  @@index([roastId])
  @@index([descriptorId])
}
